PORT=3099
NODE_ENV=development

# MongoDB Atlas (Cloud - Free & No Installation)
# 1. Sign up at https://www.mongodb.com/cloud/atlas
# 2. Create free cluster
# 3. Replace USERNAME, PASSWORD, CLUSTER with your values
# MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/rentverse?retryWrites=true&w=majority

# OR use local MongoDB (requires installation)
MONGO_URI=mongodb://localhost:27017/rentverse

JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
COOKIE_EXPIRE=5

STRIPE_API_KEY=test_api_key
STRIPE_SECRET_KEY=test_secret_key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SERVICE=gmail
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_password

SENDGRID_API_KEY=SG.your_api_key
SENDGRID_MAIL=your_email@gmail.com
SENDGRID_RESET_TEMPLATEID=d-template_id
SENDGRID_ORDER_TEMPLATEID=d-template_id

CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_secret

PAYTM_MID=your_merchant_id
PAYTM_MERCHANT_KEY=your_merchant_key
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CHANNEL_ID=WEB
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CUST_ID=your_customer_id
